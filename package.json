{
  "name": "scatter.js",
  "version": "0.1.0",
  "description": "Inline Bun workers with lock-free shared-memory channels. Scatter your work across all cores.",
  "author": "Dennis Kraemer <dkraemerwork@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dkraemerwork/scatter.git"
  },
  "bugs": {
    "url": "https://github.com/dkraemerwork/scatter/issues"
  },
  "homepage": "https://github.com/dkraemerwork/scatter#readme",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "sideEffects": false,
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./decorators": {
      "import": "./src/decorators/index.ts",
      "types": "./src/decorators/index.ts"
    },
    "./native": {
      "import": "./src/native/index.ts",
      "types": "./src/native/index.ts"
    }
  },
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "bun run tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun test"
  },
  "keywords": [
    "bun",
    "worker",
    "thread",
    "inline",
    "shared-memory",
    "lock-free",
    "ring-buffer",
    "SharedArrayBuffer",
    "concurrency",
    "parallel"
  ],
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "beta"
  }
}
